# ── Foreman Pipeline Tuning Constants ────────────────────────────────────
#
# Copy this file to .env and adjust values for your environment.
# All variables are optional — sensible production defaults are used when unset.
# Changes take effect on the next process start (not hot-reloaded).
#
# ─────────────────────────────────────────────────────────────────────────

# ── Phase budget limits (USD) ─────────────────────────────────────────────
# Controls how much each pipeline phase may spend before being terminated.
# Increase these if agents are consistently hitting budget limits.

# Explorer phase — uses Haiku model, so low budget is usually sufficient
FOREMAN_EXPLORER_BUDGET_USD=1.00

# Developer phase — main implementation work (most expensive phase)
FOREMAN_DEVELOPER_BUDGET_USD=5.00

# QA phase — test verification and fixing
FOREMAN_QA_BUDGET_USD=3.00

# Reviewer phase — independent code review
FOREMAN_REVIEWER_BUDGET_USD=2.00

# Planning step budget — one-off PRD/TRD plan generation steps
FOREMAN_PLAN_STEP_BUDGET_USD=3.00

# ── Timeout values (milliseconds) ────────────────────────────────────────
# Increase these if you see timeout errors; decrease for faster failure detection.

# How often the single-agent mode flushes progress to the store
FOREMAN_PROGRESS_FLUSH_MS=2000

# Timeout for git add/commit/push during pipeline finalization
FOREMAN_GIT_OPERATION_TIMEOUT_MS=30000

# Timeout for resetting a seed status back to open after a stuck/failed run
FOREMAN_SEED_CLOSURE_TIMEOUT_MS=10000

# Timeout for running the test suite after a merge (5 minutes default)
FOREMAN_TEST_EXECUTION_TIMEOUT_MS=300000

# Timeout for the LLM TRD decomposition call (10 minutes default; large TRDs may need more)
FOREMAN_LLM_DECOMPOSE_TIMEOUT_MS=600000

# Watch-UI polling interval — how often the live dashboard refreshes
FOREMAN_MONITOR_POLL_MS=3000

# Stale pending-run threshold in hours (used by `foreman doctor`)
FOREMAN_STALE_RUN_HOURS=24

# ── Retry / recovery limits ───────────────────────────────────────────────
# Controls how many times failed phases are retried before giving up.

# How many times the developer phase may be re-run after QA or review failure
FOREMAN_MAX_DEV_RETRIES=2

# Maximum stuck-run recovery attempts before marking a run as permanently failed
FOREMAN_MAX_RECOVERY_RETRIES=3

# Minutes of inactivity before a running agent is considered stuck
FOREMAN_STUCK_DETECTION_MINUTES=15

# ── Buffer sizes (bytes) ──────────────────────────────────────────────────
# maxBuffer for child-process output from git, gh, and claude CLI calls.
# Increase if you see "stdout maxBuffer exceeded" errors on large repositories.

# 10 MB default — covers most normal git/test output
FOREMAN_BUFFER_SIZE_BYTES=10485760
