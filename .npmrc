# .npmrc — npm registry configuration for @oftheangels/foreman
#
# LOCAL DEVELOPMENT:
#   Do NOT commit a personal access token here. Instead, authenticate
#   once via `npm login --scope=@oftheangels` which stores your credentials
#   in your user-level ~/.npmrc automatically.
#
# GITHUB ACTIONS (CI/CD):
#   The NPM_TOKEN environment variable is injected by setup-node@v4 when
#   `registry-url` is set. The line below enables that authentication path.
#
# See CONTRIBUTING.md for full setup instructions.

registry=https://registry.npmjs.org/
//registry.npmjs.org/:_authToken=${NPM_TOKEN}
