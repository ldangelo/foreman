node_modules/
dist/
.devbox/
.foreman/
*.db
.env

# Legacy Dolt database files
.dolt/

# TRD Implementation State
.trd-state/

# Foreman worktrees
.foreman-worktrees/

# Agent report files (archived to .foreman/reports/ on merge)
# Leading / anchors each pattern to the repo root so it cannot accidentally
# match source files in subdirectories (e.g. templates/reviewer-prompt.md).
/EXPLORER_REPORT*.md
/DEVELOPER_REPORT*.md
/QA_REPORT*.md
/REVIEW*.md
/FINALIZE_REPORT*.md
/TRIAGE_REPORT*.md
/*_SESSION_SUMMARY*.md
/TASK.md
/AGENTS.md
!/AGENTS.md

# bv (beads viewer) local config and caches
.bv/

# br (beads_rust) shell history and bv lock
.beads/.br_history/
.beads/.bv.lock

# Backup files
*.bak

# Session logs
SessionLogs/
SESSION_LOG.md
RUN_LOG.md

# Claude Code local config and worktrees
.claude/settings.local.json
.claude/worktrees/

# oh-my-codex runtime state
.omx/

var/
dist-new-*/
