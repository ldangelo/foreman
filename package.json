{
  "name": "@oftheangels/foreman",
  "version": "0.1.0",
  "description": "Multi-agent AI coding orchestrator with native task management, git worktree isolation, and compatibility fallback for legacy beads flows",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "foreman": "bin/foreman"
  },
  "files": [
    "dist/",
    "bin/",
    "src/defaults/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "npm run build",
    "clean": "rm -rf dist/",
    "build": "node scripts/build-atomic.js",
    "rebuild": "npm run clean && npm run build",
    "build:atomic": "node scripts/build-atomic.js",
    "dev": "tsx watch src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "bundle": "tsx scripts/bundle.ts",
    "compile-binary": "tsx scripts/compile-binary.ts --all",
    "compile-binary:dry-run": "tsx scripts/compile-binary.ts --all --dry-run",
    "build:binaries": "npm run build && npm run bundle:cjs && npm run compile-binary",
    "build:binaries:dry-run": "npm run build && npm run bundle:cjs && npm run compile-binary:dry-run",
    "test": "npm run test:ci",
    "test:watch": "vitest -c vitest.config.ts",
    "test:unit": "vitest run -c vitest.unit.config.ts",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:e2e:smoke": "vitest run -c vitest.e2e.smoke.config.ts",
    "test:e2e:full-run": "vitest run -c vitest.e2e.full-run.config.ts",
    "test:e2e": "npm run test:e2e:smoke && npm run test:e2e:full-run",
    "test:system": "vitest run -c vitest.system.config.ts",
    "test:ci": "npm run test:unit && npm run test:integration && npm run test:e2e:smoke && npm run test:e2e:full-run",
    "test:all": "npm run test:ci && npm run test:e2e:full-run && npm run test:system",
    "test:report:unit": "mkdir -p .foreman/test-reports && vitest run -c vitest.unit.config.ts --reporter=json --outputFile=.foreman/test-reports/unit.json || test -f .foreman/test-reports/unit.json",
    "test:report:integration": "mkdir -p .foreman/test-reports && vitest run -c vitest.integration.config.ts --reporter=json --outputFile=.foreman/test-reports/integration.json || test -f .foreman/test-reports/integration.json",
    "test:report:e2e:smoke": "mkdir -p .foreman/test-reports && vitest run -c vitest.e2e.smoke.config.ts --reporter=json --outputFile=.foreman/test-reports/e2e-smoke.json || test -f .foreman/test-reports/e2e-smoke.json",
    "test:report:e2e:full-run": "mkdir -p .foreman/test-reports && vitest run -c vitest.e2e.full-run.config.ts --reporter=json --outputFile=.foreman/test-reports/e2e-full-run.json || test -f .foreman/test-reports/e2e-full-run.json",
    "test:report:system": "mkdir -p .foreman/test-reports && vitest run -c vitest.system.config.ts --reporter=json --outputFile=.foreman/test-reports/system.json || test -f .foreman/test-reports/system.json",
    "test:report:ci": "mkdir -p .foreman/test-reports && npm run test:report:unit && npm run test:report:integration && npm run test:report:e2e:smoke && npm run test:report:e2e:full-run",
    "prebuilds:download": "tsx scripts/download-prebuilds.ts",
    "prebuilds:download:force": "tsx scripts/download-prebuilds.ts --force",
    "prebuilds:status": "tsx scripts/download-prebuilds.ts --status",
    "bundle:cjs": "tsx scripts/bundle-cjs.ts",
    "lint": "eslint src/ scripts/ --ext .ts",
    "lint:fix": "eslint src/ scripts/ --ext .ts --fix"
  },
  "keywords": [
    "ai",
    "multi-agent",
    "coding",
    "orchestration",
    "openclaw",
    "task-management",
    "native-tasks"
  ],
  "author": "Leo D'Angelo",
  "license": "MIT",
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.62.0",
    "@types/blessed": "^0.1.27",
    "@types/js-yaml": "^4.0.9",
    "better-sqlite3": "^12.6.2",
    "blessed": "^0.1.81",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "js-yaml": "^4.1.1",
    "ora": "^9.3.0",
    "react": "^19.2.4",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "pkg": {
    "assets": [
      "dist/package.json"
    ]
  }
}
