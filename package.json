{
  "name": "foreman",
  "version": "0.1.0",
  "description": "Multi-agent coding orchestrator built on OpenClaw + Beads",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "foreman": "bin/foreman"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-assets.js",
    "dev": "tsx watch src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "ai",
    "multi-agent",
    "coding",
    "orchestration",
    "openclaw",
    "beads"
