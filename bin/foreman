#!/usr/bin/env node
// Foreman — Multi-agent AI coding orchestrator
// Node.js shim for npm global installation
// Loads dist/cli/index.js (compiled from src/cli/index.ts)

import { fileURLToPath } from 'url';
import { dirname, resolve } from 'path';
import { createRequire } from 'module';

const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);

// Resolve dist/cli/index.js relative to this shim (bin/ → ../dist/cli/index.js)
const entryPoint = resolve(__dirname, '..', 'dist', 'cli', 'index.js');

try {
  const mod = await import(entryPoint);
  if (mod && typeof mod === 'object' && 'program' in mod && mod.program && typeof mod.program.parse === 'function') {
    mod.program.parse(process.argv);
  }
} catch (err) {
  if (err && typeof err === 'object' && 'code' in err && err.code === 'ERR_MODULE_NOT_FOUND') {
    console.error(
      'Error: foreman is not built. Run `npm run build` first.\n' +
      `Tried to load: ${entryPoint}`
    );
    process.exit(1);
  }
  throw err;
}
